---
interface Props {
  id?: number;
  tema?: string;
  titulo: string;
  descripcion?: string;
  contenido?: string;
  user_id?: string;  
}
const { titulo, descripcion, contenido, tema } = Astro.props;

function getTipoContenido(url?: string) {
  if (!url) return null;
  const ext = url.split(".").pop()?.toLowerCase();
  if (["mp3", "wav", "ogg", "m4a"].includes(ext ?? "")) return "audio";
  if (["mp4", "webm", "ogg"].includes(ext ?? "")) return "video";
  if (url.includes("youtube.com") || url.includes("youtu.be")) return "youtube";
  return null;
}

function getYoutubeId(url: string) {
  const match = url.match(/(?:v=|youtu\.be\/)([^&?/]+)/);
  return match ? match[1] : null;
}

const tipoContenido = getTipoContenido(contenido);
---

<article class="podcast-card">
  {tema && <span class="tema">{tema}</span>}
  <h3>{titulo}</h3>
  {descripcion && <p class="descripcion">{descripcion}</p>}

  {tipoContenido === "audio" && (
    <audio controls preload="metadata" class="player">
      <source src={contenido} />
      Tu navegador no soporta audio.
    </audio>
  )}

  {tipoContenido === "video" && (
    <video controls preload="metadata" class="player">
      <source src={contenido} />
      Tu navegador no soporta video.
    </video>
  )}

  {tipoContenido === "youtube" && contenido && (
    <div class="youtube-wrapper">
      <iframe
        src={`https://www.youtube.com/embed/${getYoutubeId(contenido)}`}
        title={titulo}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  )}

  {!tipoContenido && contenido && (
    <a href={contenido} target="_blank" rel="noopener noreferrer">
      Ver contenido
    </a>
  )}
</article>

<style>
  .podcast-card {
    padding: 1.25rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #fff;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tema {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #0070f3;
    letter-spacing: 0.05em;
  }

  h3 { margin: 0; font-size: 1.1rem; }

  .descripcion { margin: 0; color: #555; font-size: 0.95rem; }

  .player { width: 100%; border-radius: 4px; }

  .youtube-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
  }

  .youtube-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }
</style>