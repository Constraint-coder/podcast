---
interface Props {
  perfil: any;
}

const { perfil } = Astro.props;

const user = perfil?.user ?? {};

const nombre      = user?.nombre       ?? "";
const apellido    = user?.apellido     ?? "";
const email       = user?.email        ?? "";
const ultimoLogin = user?.ultimo_login ?? null;
const activo      = user?.esta_activo  ?? false;

const fotoUrl = perfil?.foto_perfil
  ? `http://127.0.0.1:8000/storage/${perfil.foto_perfil}`
  : null;
---

<div class="cv" id="curriculum" data-nombre={nombre} data-apellido={apellido}>

  <!-- HEADER -->
  <div class="cv__header">
    <div class="cv__avatar">
      {fotoUrl ? (
        <img id="foto-perfil" src={fotoUrl} data-src={fotoUrl} alt="perfil" />
      ) : (
        <div class="cv__avatar-fallback">
          {nombre?.charAt(0) ?? "U"}{apellido?.charAt(0) ?? ""}
        </div>
      )}
    </div>

    <div class="cv__hero">
      <h1>{nombre} {apellido}</h1>
      {perfil?.titulo && <p class="cv__titulo">{perfil.titulo}</p>}

      <div class="cv__meta">
        <span>✉️ {email || "—"}</span>
        {perfil?.telefono && <span>📞 {perfil.telefono}</span>}
        {perfil?.ubicacion && <span>📍 {perfil.ubicacion}</span>}
        {perfil?.url_sitio_web && <span>🌐 {perfil.url_sitio_web}</span>}
        {perfil?.url_linkedin && <span>💼 {perfil.url_linkedin}</span>}
        {perfil?.url_github && <span>🐙 {perfil.url_github}</span>}
        {perfil?.fecha_nacimiento && <span>🎂 {perfil.fecha_nacimiento}</span>}
        <span>{activo ? "🟢 Activo" : "🔴 Inactivo"}</span>
        {ultimoLogin && (
          <span>🕒 {new Date(ultimoLogin).toLocaleDateString()}</span>
        )}
      </div>
    </div>
  </div>

  <!-- ACCIONES -->
  <div class="cv__acciones no-print">
    <a class="btn btn--blue" href={`/usuario/${user.id}/publicaciones`}>📚 Publicaciones</a>
    <a class="btn btn--dark" href={`/usuario/${user.id}/podcast`}>🎙️ Podcasts</a>
    <button class="btn btn--green" id="download-pdf" type="button">📄 Descargar PDF</button>
  </div>

  <!-- BODY -->
  <div class="cv__body">

    <!-- COLUMNA IZQUIERDA -->
    <div class="cv__left">

      <!-- SOBRE MÍ -->
      <section class="cv__section">
        <h2 class="cv__section-title">Sobre mí</h2>
        <p class="cv__text">{perfil?.sobre_mi || "Sin información."}</p>
      </section>

      <!-- EXPERIENCIA -->
      <section class="cv__section">
        <h2 class="cv__section-title">Experiencia laboral</h2>
        {perfil?.experienciaLaboral?.length > 0 ? (
          perfil.experienciaLaboral.map((e: any) => (
            <div class="cv__item">
              <div class="cv__item-header">
                <strong>{e.descripcion_puesto || "Puesto"}</strong>
                <small>{e.fecha_inicio || "—"} — {e.fecha_fin || "Actualidad"}</small>
              </div>
              <p>{e.nombre_empresa || "Empresa"}</p>
              {e.direccion && <span class="cv__muted">📍 {e.direccion}</span>}
            </div>
          ))
        ) : (
          <p class="cv__empty">Sin experiencia registrada.</p>
        )}
      </section>

      <!-- EDUCACIÓN -->
      <section class="cv__section">
        <h2 class="cv__section-title">Educación</h2>
        {perfil?.educacion?.length > 0 ? (
          perfil.educacion.map((e: any) => (
            <div class="cv__item">
              <div class="cv__item-header">
                <strong>{e.titulo || "Título"}</strong>
                <small>{e.fecha_inicio || "—"} — {e.fecha_fin || "Actualidad"}</small>
              </div>
              <p>{e.nombre_institucion || "Institución"}</p>
            </div>
          ))
        ) : (
          <p class="cv__empty">Sin educación registrada.</p>
        )}
      </section>

      <!-- PROYECTOS -->
      <section class="cv__section">
        <h2 class="cv__section-title">Proyectos</h2>
        {perfil?.proyecto?.length > 0 ? (
          perfil.proyecto.map((p: any) => (
            <div class="cv__item">
              <strong>{p.proyecto || "Proyecto"}</strong>
              {p.descripcion && <p>{p.descripcion}</p>}
              {p.fecha_inicio && (
                <small>{p.fecha_inicio} — {p.fecha_fin || "En curso"}</small>
              )}
              {p.url_proyecto && (
                <a href={p.url_proyecto} target="_blank" class="cv__link">
                  Ver proyecto →
                </a>
              )}
            </div>
          ))
        ) : (
          <p class="cv__empty">Sin proyectos registrados.</p>
        )}
      </section>

      <!-- CERTIFICACIONES -->
      <section class="cv__section">
        <h2 class="cv__section-title">Certificaciones</h2>
        {perfil?.certificacion?.length > 0 ? (
          perfil.certificacion.map((c: any) => (
            <div class="cv__item">
              <div class="cv__item-header">
                <strong>{c.certificacion || "Certificación"}</strong>
                {c.fecha_emision && <small>Emitida: {c.fecha_emision}</small>}
              </div>
              {c.organizacion && <p>{c.organizacion}</p>}
              {c.url_credencial && (
                <a href={c.url_credencial} target="_blank" class="cv__link">
                  Ver credencial →
                </a>
              )}
            </div>
          ))
        ) : (
          <p class="cv__empty">Sin certificaciones registradas.</p>
        )}
      </section>

    </div>

    <!-- COLUMNA DERECHA -->
    <div class="cv__right">

      <!-- HABILIDADES -->
      <section class="cv__section">
        <h2 class="cv__section-title">Habilidades</h2>
        {perfil?.habilidad?.length > 0 ? (
          <div class="cv__tags">
            {perfil.habilidad.map((h: any) => (
              <span class="cv__tag">{h.habilidad}</span>
            ))}
          </div>
        ) : (
          <p class="cv__empty">Sin habilidades registradas.</p>
        )}
      </section>

      <!-- IDIOMAS -->
      <section class="cv__section">
        <h2 class="cv__section-title">Idiomas</h2>
        {perfil?.idioma?.length > 0 ? (
          perfil.idioma.map((i: any) => (
            <div class="cv__idioma">
              <span>{i.idioma || "Idioma"}</span>
              <strong>{i.nivel || "—"}</strong>
            </div>
          ))
        ) : (
          <p class="cv__empty">Sin idiomas registrados.</p>
        )}
      </section>

      <!-- CONTACTO EXTRA -->
      <section class="cv__section">
        <h2 class="cv__section-title">Contacto</h2>
        <div class="cv__contact">
          <p>✉️ {email || "—"}</p>
          <p>📞 {perfil?.telefono || "—"}</p>
          <p>📍 {perfil?.ubicacion || "—"}</p>
          {perfil?.url_sitio_web && (
            <a href={perfil.url_sitio_web} target="_blank" class="cv__link">
              🌐 Sitio web
            </a>
          )}
          {perfil?.url_linkedin && (
            <a href={perfil.url_linkedin} target="_blank" class="cv__link">
              💼 LinkedIn
            </a>
          )}
          {perfil?.url_github && (
            <a href={perfil.url_github} target="_blank" class="cv__link">
              🐙 GitHub
            </a>
          )}
        </div>
      </section>

    </div>
  </div>
</div>

<style>
  .cv {
    max-width: 960px;
    margin:0 auto;
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,.1);
    overflow: hidden;
    font-family: system-ui, sans-serif;
    color: #0f172a;
  }

  /* HEADER */
  .cv__header {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2rem 2.5rem;
    background: linear-gradient(135deg, #1e3a5f, #2563eb);
    color: white;
  }

  .cv__avatar {
    flex-shrink: 0;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid rgba(255,255,255,.4);
  }

  .cv__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cv__avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.2);
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
  }

  .cv__hero h1 {
    margin: 0 0 4px;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .cv__titulo {
    margin: 0 0 10px;
    font-size: 1rem;
    opacity: .85;
  }

  .cv__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.78rem;
    opacity: .9;
  }

  .cv__meta span {
    background: rgba(255,255,255,.15);
    padding: 3px 10px;
    border-radius: 999px;
  }

  /* ACCIONES */
  .cv__acciones {
    display: flex;
    gap: 10px;
    padding: 1rem 2.5rem;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    flex-wrap: wrap;
  }

  .btn {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity .15s;
  }

  .btn:hover { opacity: .85; }
  .btn--blue  { background: #2563eb; color: white; }
  .btn--dark  { background: #111827; color: white; }
  .btn--green { background: #16a34a; color: white; }
  .btn--green:disabled { opacity: .6; cursor: not-allowed; }

  /* BODY */
  .cv__body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 0;
  }

  .cv__left {
    padding: 2rem 2.5rem;
    border-right: 1px solid #e2e8f0;
  }

  .cv__right {
    padding: 2rem 1.5rem;
    background: #f8fafc;
  }

  /* SECCIONES */
  .cv__section {
    margin-bottom: 2rem;
  }

  .cv__section-title {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #2563eb;
    margin: 0 0 .75rem;
    padding-bottom: .4rem;
    border-bottom: 2px solid #dbeafe;
  }

  /* ITEMS */
  .cv__item {
    padding: .75rem 0;
    border-bottom: 1px solid #f1f5f9;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cv__item:last-child { border-bottom: none; }

  .cv__item-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .cv__item strong { font-size: 0.9rem; color: #0f172a; }
  .cv__item p { margin: 0; font-size: 0.85rem; color: #475569; }
  .cv__item small { font-size: 0.75rem; color: #94a3b8; white-space: nowrap; }

  .cv__muted { font-size: 0.78rem; color: #94a3b8; }

  .cv__text {
    margin: 0;
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.7;
  }

  .cv__empty {
    font-size: 0.8rem;
    color: #94a3b8;
    font-style: italic;
    margin: 0;
  }

  .cv__link {
    font-size: 0.8rem;
    color: #2563eb;
    text-decoration: none;
    margin-top: 2px;
  }

  .cv__link:hover { text-decoration: underline; }

  /* TAGS */
  .cv__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .cv__tag {
    background: #dbeafe;
    color: #1e40af;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* IDIOMAS */
  .cv__idioma {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 10px;
    margin-bottom: 6px;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.85rem;
  }

  .cv__idioma strong { color: #2563eb; font-size: 0.8rem; }

  /* CONTACTO */
  .cv__contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.82rem;
    color: #475569;
  }

  .cv__contact p { margin: 0; }

  @media (max-width: 700px) {
    .cv__header { flex-direction: column; text-align: center; }
    .cv__body { grid-template-columns: 1fr; }
    .cv__left { border-right: none; border-bottom: 1px solid #e2e8f0; }
    .cv__right { background: white; }
    .cv__acciones { padding: 1rem; }
  }
</style>

<script>
  import html2pdf from "html2pdf.js";

  const curriculum = document.getElementById("curriculum");
  const btn        = document.getElementById("download-pdf");
  const nombre     = curriculum?.dataset.nombre   ?? "CV";
  const apellido   = curriculum?.dataset.apellido ?? "";

  async function imagenABase64(url) {
    try {
      const res  = await fetch(`/api/imagen?src=${encodeURIComponent(url)}`);
      const blob = await res.blob();
      return await new Promise((resolve) => {
        const reader = new FileReader();
        reader.onloadend = () => resolve(reader.result);
        reader.readAsDataURL(blob);
      });
    } catch {
      return null;
    }
  }

  btn?.addEventListener("click", async () => {
    if (!curriculum || !btn) return;

    btn.disabled    = true;
    btn.textContent = "Generando...";

    const foto = document.getElementById("foto-perfil");
    const srcOriginal = foto?.src ?? null;

    if (foto && srcOriginal) {
      const base64 = await imagenABase64(srcOriginal);
      if (base64) foto.src = base64;
    }

    const ocultar = curriculum.querySelectorAll(".cv__acciones");
    ocultar.forEach((el) => el.style.display = "none");

    const opciones = {
      margin:      10,
      filename:    `CV-${nombre}-${apellido}.pdf`,
      image:       { type: "jpeg", quality: 0.98 },
      html2canvas: { scale: 2, useCORS: false, logging: false },
      jsPDF:       { unit: "mm", format: "a4", orientation: "portrait" },
    };

    try {
      await html2pdf().set(opciones).from(curriculum).save();
    } catch (error) {
      console.error("Error al generar PDF:", error);
      alert("No se pudo generar el PDF.");
    } finally {
      if (foto && srcOriginal) foto.src = srcOriginal;
      ocultar.forEach((el) => el.style.display = "");
      btn.disabled    = false;
      btn.textContent = "📄 Descargar PDF";
    }
  });
</script>