---
import CrearPodcast
from "@/components/podcast/crearpodcast.astro";

// IMPORTAR TU API PODCAST
import { getPodcast } from "@/lib/podcast-server.js";

// COMPONENTE CARD
import PodcastCard
from "@/components/podcast/podcast.astro";

const token =
  Astro.cookies.get("token")?.value;

const page = Number(
  Astro.url.searchParams.get("page") || 1
);

let initialData = {
  data: [],
  total: 0,
  current_page: 1,
  last_page: 1,
};

try {

  initialData =
    await getPodcast(
      token,
      page
    );

} catch (error) {

  console.error(error);
}
---

<section class="view-card">

  <div class="view-header">

    <h2>
      🎙️ Podcast
    </h2>

    <span>
      {initialData.total}
      podcasts
    </span>

  </div>

  <CrearPodcast />

</section>

<!-- FEED -->
<section class="feed-section">

  <div class="feed">

    {Array.isArray(initialData.data) &&
    initialData.data.length > 0 ? (

      initialData.data.map((podcast) => (

        <div class="item-wrapper">

          <PodcastCard {...podcast} />

        </div>

      ))

    ) : (

      <div class="empty-feed">

        <h3>
          No hay podcasts
        </h3>

      </div>

    )}

  </div>

</section>
<style>

.view-card,
.feed-section{

  background:
    rgba(255,255,255,.75);

  backdrop-filter:blur(18px);

  border:
    1px solid rgba(255,255,255,.5);

  border-radius:30px;

  padding:2rem;

  margin-bottom:1.5rem;

  box-shadow:
    0 12px 35px rgba(15,23,42,.06);
}

/* HEADER */

.view-header{

  display:flex;

  justify-content:space-between;

  align-items:center;

  gap:1rem;

  margin-bottom:2rem;

  flex-wrap:wrap;
}

.view-header h2{

  margin:0;

  font-size:2rem;

  color:#0f172a;

  font-weight:900;
}

.view-header p{

  margin-top:.5rem;

  color:#64748b;
}

/* BADGE */

.total-badge{

  padding:
    .7rem
    1rem;

  border-radius:999px;

  background:
    linear-gradient(
      135deg,
      #2563eb,
      #7c3aed
    );

  color:white;

  font-weight:700;

  font-size:.9rem;

  box-shadow:
    0 10px 25px rgba(37,99,235,.2);
}

/* FEED */

.feed{

  display:flex;

  flex-direction:column;

  gap:1.2rem;
}

.item-wrapper{

  animation:
    fadeIn .3s ease;
}

/* EMPTY */

.empty-feed{

  text-align:center;

  padding:4rem 1rem;
}

.empty-feed h3{

  margin-bottom:.5rem;

  font-size:1.5rem;

  color:#0f172a;
}

.empty-feed p{

  color:#64748b;
}

/* PAGINACION */

.paginacion{

  display:flex;

  justify-content:center;

  align-items:center;

  gap:1rem;

  flex-wrap:wrap;

  margin-top:2rem;
}

/* BOTONES */

.btn-pag{

  text-decoration:none;

  padding:
    .9rem
    1.4rem;

  border-radius:16px;

  font-weight:700;

  color:white;

  background:
    linear-gradient(
      135deg,
      #2563eb,
      #7c3aed
    );

  transition:.25s ease;

  box-shadow:
    0 10px 20px rgba(37,99,235,.2);
}

.btn-pag:hover{

  transform:
    translateY(-3px);

  box-shadow:
    0 18px 30px rgba(37,99,235,.28);
}

/* INFO */

.info-pag{

  display:flex;

  align-items:center;

  gap:.5rem;

  padding:
    .9rem
    1.2rem;

  border-radius:16px;

  background:
    rgba(255,255,255,.75);

  border:
    1px solid #e2e8f0;

  color:#64748b;

  font-weight:600;
}

.info-pag strong{

  color:#0f172a;
}

/* ANIMACION */

@keyframes fadeIn{

  from{

    opacity:0;

    transform:
      translateY(10px);
  }

  to{

    opacity:1;

    transform:
      translateY(0);
  }
}

/* RESPONSIVE */

@media (max-width:768px){

  .view-card,
  .feed-section{

    padding:1.3rem;
  }

  .view-header{

    align-items:flex-start;
  }

  .view-header h2{

    font-size:1.6rem;
  }
}

</style>