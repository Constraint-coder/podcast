---
import BaseLayout from "../layouts/Layout.astro";
import '../styles/register.css'
// Si ya está logueado, redirigir al dashboard
const token = Astro.cookies.get("token")?.value;
if (token) {
  return Astro.redirect("/dashboard");
}
---

<BaseLayout>
  <div class="register-container">
    <div class="register-card">
      <div class="register-header">
        <div class="register-icon">
          <svg width="64" height="64" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.78168 19.25H13.2183C13.7828 19.25 14.227 18.7817 14.1145 18.2285C13.804 16.7012 12.7897 14 9.5 14C6.21031 14 5.19605 16.7012 4.88549 18.2285C4.773 18.7817 5.21718 19.25 5.78168 19.25Z"></path>
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 14C17.8288 14 18.6802 16.1479 19.0239 17.696C19.2095 18.532 18.5333 19.25 17.6769 19.25H16.75"></path>
            <circle cx="9.5" cy="7.5" r="2.75" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></circle>
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.75 10.25C16.2688 10.25 17.25 9.01878 17.25 7.5C17.25 5.98122 16.2688 4.75 14.75 4.75"></path>
          </svg>
        </div>
        <h1>Crear Cuenta</h1>
        <p class="subtitle">Únete a nuestra comunidad</p>
      </div>

      <form id="registerForm">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="3.25" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></circle>
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.8475 19.25H17.1525C18.2944 19.25 19.174 18.2681 18.6408 17.2584C17.8563 15.7731 16.068 14 12 14C7.93201 14 6.14367 15.7731 5.35924 17.2584C4.82597 18.2681 5.70558 19.25 6.8475 19.25Z"></path>
              </svg>
              Nombre
            </label>
            <input 
              type="text" 
              id="nombre" 
              name="nombre" 
              placeholder="Tu nombre" 
              required 
              autocomplete="given-name"
            />
          </div>

          <div class="form-group">
            <label for="apellido">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="3.25" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></circle>
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.8475 19.25H17.1525C18.2944 19.25 19.174 18.2681 18.6408 17.2584C17.8563 15.7731 16.068 14 12 14C7.93201 14 6.14367 15.7731 5.35924 17.2584C4.82597 18.2681 5.70558 19.25 6.8475 19.25Z"></path>
              </svg>
              Apellido
            </label>
            <input 
              type="text" 
              id="apellido" 
              name="apellido" 
              placeholder="Tu apellido" 
              required 
              autocomplete="family-name"
            />
          </div>
        </div>

        <div class="form-group">
          <label for="email">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.75 7.75C4.75 6.64543 5.64543 5.75 6.75 5.75H17.25C18.3546 5.75 19.25 6.64543 19.25 7.75V16.25C19.25 17.3546 18.3546 18.25 17.25 18.25H6.75C5.64543 18.25 4.75 17.3546 4.75 16.25V7.75Z"></path>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.5 6.5L12 12.25L18.5 6.5"></path>
            </svg>
            Email
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="tu@email.com" 
            required 
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <label for="fecha_nacimiento">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.75 8.75C4.75 7.64543 5.64543 6.75 6.75 6.75H17.25C18.3546 6.75 19.25 7.64543 19.25 8.75V17.25C19.25 18.3546 18.3546 19.25 17.25 19.25H6.75C5.64543 19.25 4.75 18.3546 4.75 17.25V8.75Z"></path>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 4.75V8.25"></path>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 4.75V8.25"></path>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.75 10.75H16.25"></path>
            </svg>
            Fecha de Nacimiento
          </label>
          <input 
            type="date" 
            id="fecha_nacimiento" 
            name="fecha_nacimiento" 
            required 
            autocomplete="bday"
          />
        </div>

        <div class="form-group">
          <label for="password">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.75 11.75C5.75 11.1977 6.19772 10.75 6.75 10.75H17.25C17.8023 10.75 18.25 11.1977 18.25 11.75V17.25C18.25 18.3546 17.3546 19.25 16.25 19.25H7.75C6.64543 19.25 5.75 18.3546 5.75 17.25V11.75Z"></path>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.75 10.5V10.3427C7.75 8.78147 7.65607 7.04125 8.74646 5.9239C9.36829 5.2867 10.3745 4.75 12 4.75C13.6255 4.75 14.6317 5.2867 15.2535 5.9239C16.3439 7.04125 16.25 8.78147 16.25 10.3427V10.5"></path>
            </svg>
            Contraseña
          </label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="Mínimo 6 caracteres" 
            required 
            minlength="6"
            autocomplete="new-password"
          />
          <div class="password-strength" id="password-strength">
            <div class="strength-meter">
              <div class="strength-meter-fill" id="strength-meter-fill"></div>
            </div>
            <small id="strength-text"></small>
          </div>
        </div>

        <div class="form-group">
          <label for="password_confirmation">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.75 11.75C5.75 11.1977 6.19772 10.75 6.75 10.75H17.25C17.8023 10.75 18.25 11.1977 18.25 11.75V17.25C18.25 18.3546 17.3546 19.25 16.25 19.25H7.75C6.64543 19.25 5.75 18.3546 5.75 17.25V11.75Z"></path>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.75 10.5V10.3427C7.75 8.78147 7.65607 7.04125 8.74646 5.9239C9.36829 5.2867 10.3745 4.75 12 4.75C13.6255 4.75 14.6317 5.2867 15.2535 5.9239C16.3439 7.04125 16.25 8.78147 16.25 10.3427V10.5"></path>
            </svg>
            Confirmar Contraseña
          </label>
          <input 
            type="password" 
            id="password_confirmation" 
            name="password_confirmation" 
            placeholder="Repite tu contraseña" 
            required 
            minlength="6"
            autocomplete="new-password"
          />
        </div>


        <button type="submit" class="btn-register">
          <span id="btn-text">Crear Cuenta</span>
          <span id="btn-loading" class="hidden">
            <svg class="spinner" viewBox="0 0 50 50" width="20" height="20">
              <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
            </svg>
            Creando cuenta...
          </span>
        </button>
      </form>

      <div id="error" class="alert alert-error hidden"></div>
      <div id="success" class="alert alert-success hidden"></div>

      <div class="register-footer">
        <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
      </div>
    </div>
  </div>



  <script>
    import { register } from "../lib/auth";

    const form = document.getElementById("registerForm");
    const btnText = document.getElementById("btn-text");
    const btnLoading = document.getElementById("btn-loading");
    const errorEl = document.getElementById("error");
    const successEl = document.getElementById("success");
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    const passwordInput = document.getElementById("password") as HTMLInputElement;
    const strengthMeterFill = document.getElementById("strength-meter-fill");
    const strengthText = document.getElementById("strength-text");

    // Verificador de fortaleza de contraseña
    passwordInput?.addEventListener('input', () => {
      const password = passwordInput.value;
      let strength = 0;
      
      if (password.length >= 6) strength++;
      if (password.length >= 10) strength++;
      if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
      if (/\d/.test(password)) strength++;
      if (/[^a-zA-Z0-9]/.test(password)) strength++;

      strengthMeterFill?.classList.remove('weak', 'medium', 'strong');
      
      if (strength <= 2) {
        strengthMeterFill?.classList.add('weak');
        if (strengthText) strengthText.textContent = 'Débil';
        if (strengthText) strengthText.style.color = '#fc8181';
      } else if (strength <= 4) {
        strengthMeterFill?.classList.add('medium');
        if (strengthText) strengthText.textContent = 'Media';
        if (strengthText) strengthText.style.color = '#f6ad55';
      } else {
        strengthMeterFill?.classList.add('strong');
        if (strengthText) strengthText.textContent = 'Fuerte';
        if (strengthText) strengthText.style.color = '#68d391';
      }
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      
      const formData = new FormData(event.target as HTMLFormElement);
      const data = {
        nombre: formData.get("nombre") as string,
        apellido: formData.get("apellido") as string,
        email: formData.get("email") as string,
        password: formData.get("password") as string,
        password_confirmation: formData.get("password_confirmation") as string,
        fecha_nacimiento: formData.get("fecha_nacimiento") as string,
      };

      // Limpiar mensajes anteriores
      if (errorEl) {
        errorEl.textContent = "";
        errorEl.classList.add("hidden");
      }
      if (successEl) {
        successEl.textContent = "";
        successEl.classList.add("hidden");
      }

      // Validación de contraseñas
      if (data.password !== data.password_confirmation) {
        if (errorEl) {
          errorEl.textContent = "Las contraseñas no coinciden";
          errorEl.classList.remove("hidden");
        }
        return;
      }

      // Validación de términos

      // Mostrar estado de carga
      if (btnText) btnText.classList.add("hidden");
      if (btnLoading) btnLoading.classList.remove("hidden");
      if (submitBtn) submitBtn.disabled = true;

      try {
        // Usar la función register de auth.js
        await register(data);

        // Éxito
        if (successEl) {
          successEl.textContent = "✨ ¡Registro exitoso! Redirigiendo al dashboard...";
          successEl.classList.remove("hidden");
        }

        // Redirigir al dashboard
        setTimeout(() => {
          window.location.href = "/dashboard";
        }, 1500);

      } catch (error: any) {
        if (errorEl) {
          errorEl.textContent = error.message || "Error al registrarse";
          errorEl.classList.remove("hidden");
        }
        console.error("Error:", error);

        // Restaurar botón
        if (btnText) btnText.classList.remove("hidden");
        if (btnLoading) btnLoading.classList.add("hidden");
        if (submitBtn) submitBtn.disabled = false;

        // Auto-ocultar error después de 5 segundos
        setTimeout(() => {
          if (errorEl) errorEl.classList.add("hidden");
        }, 5000);
      }
    });

    // Limpiar errores al empezar a escribir
    const inputs = form?.querySelectorAll('input');
    inputs?.forEach(input => {
      input.addEventListener('input', () => {
        if (errorEl) errorEl.classList.add("hidden");
      });
    });

    // Validación en tiempo real de confirmación de contraseña
    const passwordConfirmation = document.getElementById("password_confirmation") as HTMLInputElement;
    passwordConfirmation?.addEventListener('input', () => {
      if (passwordInput && passwordConfirmation.value) {
        if (passwordInput.value !== passwordConfirmation.value) {
          passwordConfirmation.style.borderColor = '#fc8181';
        } else {
          passwordConfirmation.style.borderColor = '#68d391';
        }
      }
    });
  </script>
</BaseLayout>