---
import BaseLayout from "../../layouts/LayoutNobar.astro";
import ProfileCard from "../../components/usuarios/usuarios.astro";
import { getPerfil } from "../../lib/perfil-server";

import "../../styles/global.css";
import "../../styles/curriculum.css";

const token = Astro.cookies.get("token")?.value;
if (!token) return Astro.redirect("/login");



let perfil;

try {
  perfil = await getPerfil(token);
} catch (error) { 
  console.error(error);
 return Astro.redirect("/dashboard");
}
---  
<BaseLayout>
  <div class="perfil-header">
    <a class="btnEditar" href="/editarperfil">Editar perfil</a>
    <button id="logoutBtn" class="btn btn--danger">Cerrar sesión</button>
  </div>
  <div style="flex-direction: column;">

  <ProfileCard perfil={perfil} />

</div>
<script>
  import { logout } from "@/lib/auth";
    document.getElementById("logoutBtn")?.addEventListener("click", async () => {
    try { await logout() } catch (e) { console.error(e); }
    document.cookie = "token=; path=/; max-age=0";
    window.location.href = "/login";
  });
</script>
<style>
.btnEditar {
  background-color: #2563eb;
  color: white;
  padding: 8px 16px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
 margin-right: 1rem;
  text-decoration: none;
}
.perfil-header {
       max-width: 960px;
       margin: 0 auto;
      display: flex;
      z-index: 100;
      position: relative;


  }
  .btn--danger { position: absolute; background: #dc2626; color: white; border-color: red; right: 3px; }
</style>
</BaseLayout>
